.page {
  padding: 18rpx;
}

.login-card {
  margin: 0;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #1E3A8A 0%, #1D4ED8 52%, #164E63 100%);
  color: #FFFFFF;
}

.title {
  color: #FFFFFF;
}

.subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.current-account {
  margin-top: 16rpx;
  font-size: 24rpx;
  opacity: 0.9;
}

.field {
  margin-top: 16rpx;
}

.field-label {
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.86);
}

.input {
  width: 100%;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.94);
  color: #0F172A;
  font-family: 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans SC', sans-serif;
  border: 1rpx solid rgba(255, 255, 255, 0.36);
  border-radius: 16rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  line-height: 1.4;
}

.login-btn {
  border: none;
  margin-top: 20rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: #FFFFFF;
  color: #1E3A8A;
}