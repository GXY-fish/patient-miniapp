page {
  background: #F5F7FA;
  color: #0F172A;
  font-family: 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans SC', sans-serif;
}

.card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(15, 23, 42, 0.06);
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #0F172A;
}

.subtle {
  color: #64748B;
  font-size: 26rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #0F766E, #14B8A6);
  color: #FFFFFF;
  border-radius: 999rpx;
}

.btn-secondary {
  background: #E2E8F0;
  color: #0F172A;
  border-radius: 999rpx;
}
