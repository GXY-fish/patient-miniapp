.page {
  padding: 18rpx;
  padding-bottom: 24rpx;
  background: linear-gradient(180deg, #F8FAFC 0%, #F4F7FB 55%, #EEF3F9 100%);
}

.hero-card {
  background: linear-gradient(135deg, #0F766E 0%, #115E59 52%, #164E63 100%);
  color: #FFFFFF;
  overflow: hidden;
  position: relative;
}

.hero-card::after {
  content: '';
  position: absolute;
  right: -40rpx;
  top: -60rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}

.hero-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 22rpx;
  letter-spacing: 1rpx;
}

.hero-note {
  font-size: 22rpx;
  opacity: 0.84;
}

.title {
  position: relative;
  z-index: 1;
  font-size: 38rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  opacity: 0.92;
  max-width: 560rpx;
}

.filter-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.filter-pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #EDF2F7;
  color: #334155;
  font-size: 24rpx;
}

.filter-pill.active {
  background: #0F766E;
  color: #FFFFFF;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.stat-box {
  background: linear-gradient(180deg, #FFFFFF 0%, #F8FAFC 100%);
  border-radius: 18rpx;
  padding: 20rpx;
  border: 1rpx solid #E2E8F0;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.03);
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #0F766E;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748B;
}

.case-item {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #E2E8F0;
}

.case-item:last-child {
  border-bottom: none;
}

.case-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0F172A;
}

.case-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748B;
}

.empty-tip {
  padding: 24rpx 0 8rpx;
  color: #94A3B8;
  font-size: 24rpx;
}

.empty-tip {
  color: #64748B;
  font-size: 26rpx;
}