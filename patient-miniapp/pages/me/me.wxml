<view class="page">
  <view class="card profile-card">
    <view class="title">账号中心</view>
    <view class="profile-item">当前身份：{{roleText}}</view>
    <view class="profile-item">当前账号：{{loginPhone || '未登录'}}</view>
    <view class="profile-item" wx:if="{{loginRole === 'patient' && patientName}}">患者姓名：{{patientName}}</view>
    <view class="profile-item" wx:if="{{loginRole === 'patient' && medicalNo}}">病历号：{{medicalNo}}</view>
  </view>

  <view class="card">
    <view class="section-title">账号操作</view>
    <view class="menu-item" bindtap="goRoleLogin">前往{{loginRole === 'doctor' ? '医生' : '患者'}}登录页</view>
    <view class="menu-item" bindtap="switchIdentity">切换身份</view>
    <view class="menu-item danger" bindtap="logout">退出登录</view>
  </view>
</view>
