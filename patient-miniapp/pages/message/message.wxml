<view class="page">
  <view class="card">
    <view class="title">消息提醒</view>
    <view class="subtle">医生回复、系统通知、随访提醒都会在这里展示</view>
  </view>

  <view class="card">
    <block wx:for="{{messages}}" wx:key="id">
      <view class="msg-item {{item.unread ? 'unread' : ''}}">
        <view class="msg-head">
          <text class="msg-title">{{item.title}}</text>
          <text class="msg-time">{{item.time}}</text>
        </view>
        <view class="msg-content">{{item.content}}</view>
      </view>
    </block>
  </view>
</view>
