<view class="page">
  <view class="card login-card">
    <view class="title">医生登录</view>
    <view class="subtitle">登录后进入医生工作台进行病例审核</view>
    <view class="current-account">当前账号：{{loginPhone || '未登录'}}</view>

    <view class="field">
      <view class="field-label">手机号</view>
      <input class="input" style="color:#0F172A;background-color:#FFFFFF;" value="{{phone}}" bindinput="onPhoneInput" />
    </view>
    <button class="btn-primary login-btn" bindtap="login">医生登录</button>
  </view>
</view>