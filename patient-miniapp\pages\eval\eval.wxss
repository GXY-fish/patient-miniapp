.page {
  padding-bottom: 24rpx;
}

.bind-tip {
  background: linear-gradient(135deg, #0F766E 0%, #115E59 100%);
  color: #FFFFFF;
}

.bind-title {
  font-size: 32rpx;
  font-weight: 700;
}

.bind-text {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  opacity: 0.9;
}

.bind-btn {
  margin-top: 16rpx;
  height: 84rpx;
  line-height: 84rpx;
  border: none;
  background: #FFFFFF;
  color: #0F766E;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.upload-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.upload-box {
  width: calc(33.333% - 11rpx);
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #E2E8F0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #475569;
  font-size: 26rpx;
}

.upload-image {
  width: 100%;
  height: 100%;
}

.upload-add {
  border: 2rpx dashed #94A3B8;
  background: #F8FAFC;
}

.photo-note {
  font-size: 24rpx;
  color: #64748B;
  margin-top: 12rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.radio-item {
  display: inline-flex;
  align-items: center;
  margin-right: 24rpx;
  margin-top: 16rpx;
}

.flag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin: 20rpx 0;
}

.note {
  width: 100%;
  min-height: 180rpx;
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.submit-btn {
  border: none;
  height: 88rpx;
  line-height: 88rpx;
}
